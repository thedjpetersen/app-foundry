{
  "name": "app-foundry",
  "version": "0.1.0",
  "description": "Design-system-neutral framework for independently developed application modules.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thedjpetersen/app-foundry.git"
  },
  "bugs": {
    "url": "https://github.com/thedjpetersen/app-foundry/issues"
  },
  "homepage": "https://thedjpetersen.github.io/app-foundry/",
  "keywords": [
    "application-framework",
    "domain-driven-design",
    "micro-app",
    "shell"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./generator": {
      "types": "./dist/generator/index.d.ts",
      "import": "./dist/generator/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./worker": {
      "types": "./dist/worker/index.d.ts",
      "import": "./dist/worker/index.js"
    }
  },
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "check": "tsc -p tsconfig.json --noEmit",
    "docs:build": "npm run docs:typecheck && vite build --config site/vite.config.ts && node site/finalize.mjs",
    "docs:check": "node site/check.mjs",
    "docs:dev": "vite --config site/vite.config.ts --host 127.0.0.1",
    "docs:typecheck": "tsc -p site/tsconfig.json --noEmit",
    "prepare": "npm run build",
    "validate": "npm run check && npm run build && npm run docs:build && npm run docs:check"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@astryxdesign/core": "0.1.4",
    "@cloudflare/workers-types": "^4.20260624.1",
    "@stylexjs/babel-plugin": "0.18.3",
    "@stylexjs/stylex": "0.18.3",
    "@types/node": "^26.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.2",
    "vite": "^7.3.6"
  }
}
